#!/usr/bin/env bash
# Rekon stack operator CLI -- one script for both coordinator and pod devices.
set -euo pipefail

# Stack-aware compose-file resolution:
#   1. COORD_COMPOSE_FILE (explicit)
#   2. COORD_STACK -> /opt/stacks/$COORD_STACK/compose.yaml
#   3. the sole stack under /opt/stacks/* (the common case: a pod has only the
#      pod stack installed, the coordinator only the coordinator stack)
COORD_STACKS_ROOT="${COORD_STACKS_ROOT:-/opt/stacks}"

resolve_compose_file() {
	if [[ -n ${COORD_COMPOSE_FILE:-} ]]; then
		echo "${COORD_COMPOSE_FILE}"
		return
	fi
	if [[ -n ${COORD_STACK:-} ]]; then
		echo "${COORD_STACKS_ROOT}/${COORD_STACK}/compose.yaml"
		return
	fi
	local found=()
	local f
	for f in "${COORD_STACKS_ROOT}"/*/compose.yaml; do
		[[ -f ${f} ]] && found+=("${f}")
	done
	if [[ ${#found[@]} -eq 1 ]]; then
		echo "${found[0]}"
	elif [[ ${#found[@]} -eq 0 ]]; then
		echo "${COORD_STACKS_ROOT}/coordinator/compose.yaml"
	else
		echo "coord: multiple stacks under ${COORD_STACKS_ROOT}; set COORD_STACK or COORD_COMPOSE_FILE" >&2
		printf '  %s\n' "${found[@]}" >&2
		exit 1
	fi
}

COORD_COMPOSE_FILE="$(resolve_compose_file)"
COORD_ENV_PATH="${COORD_ENV_PATH:-$(dirname "${COORD_COMPOSE_FILE}")/.env}"

compose() {
	docker compose -f "${COORD_COMPOSE_FILE}" "$@"
}

# Default shell target: explicit override, else the stack's first service.
default_service() {
	if [[ -n ${COORD_DEFAULT_SERVICE:-} ]]; then
		echo "${COORD_DEFAULT_SERVICE}"
	else
		compose config --services 2>/dev/null | head -n1
	fi
}

usage() {
	cat <<'EOF'
Usage: coord <command> [args]

Commands:
  pull              Stop stack, pull images, start stack
  start             docker compose up -d
  stop              docker compose down
  restart           docker compose restart [service]
  status            docker compose ps
  logs [service]    Follow logs (default: all services)
  shell [service]   Interactive shell in service (default: stack's first service)
  exec <service> <cmd...>  Run command in service container

Environment:
  COORD_COMPOSE_FILE   Explicit compose file (overrides stack detection)
  COORD_STACK          Stack name under /opt/stacks (e.g. coordinator, pod)
  COORD_STACKS_ROOT    Default: /opt/stacks
  COORD_ENV_PATH       Default: directory of compose file + /.env
  COORD_DEFAULT_SERVICE Default service for shell (else first service)
EOF
}

require_compose_file() {
	if [[ ! -f ${COORD_COMPOSE_FILE} ]]; then
		echo "coord: compose file not found: ${COORD_COMPOSE_FILE}" >&2
		echo "coord: set COORD_COMPOSE_FILE or install stacks/coordinator to /opt/stacks/coordinator" >&2
		exit 1
	fi
}

cmd="${1:-}"
shift || true

case "${cmd}" in
pull)
	require_compose_file
	compose down
	compose pull
	compose up -d
	;;
start)
	require_compose_file
	compose up -d
	;;
stop)
	require_compose_file
	compose down
	;;
restart)
	require_compose_file
	compose restart "$@"
	;;
status)
	require_compose_file
	compose ps
	;;
logs)
	require_compose_file
	if [[ $# -gt 0 ]]; then
		compose logs -f "$@"
	else
		compose logs -f
	fi
	;;
shell)
	require_compose_file
	service="${1:-$(default_service)}"
	if [[ -z ${service} ]]; then
		echo "coord: no service given and none found in ${COORD_COMPOSE_FILE}" >&2
		exit 1
	fi
	compose exec -it "${service}" bash
	;;
exec)
	require_compose_file
	if [[ $# -lt 2 ]]; then
		echo "coord: exec requires <service> <command...>" >&2
		exit 1
	fi
	compose exec -it "$@"
	;;
-h | --help | help | "")
	usage
	;;
*)
	echo "coord: unknown command: ${cmd}" >&2
	usage >&2
	exit 1
	;;
esac
