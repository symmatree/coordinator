#!/usr/bin/env bash
# Coordinator stack operator CLI.
set -euo pipefail

COORD_COMPOSE_FILE="${COORD_COMPOSE_FILE:-/opt/stacks/coordinator/compose.yaml}"
COORD_ENV_PATH="${COORD_ENV_PATH:-$(dirname "${COORD_COMPOSE_FILE}")/.env}"
DEFAULT_SERVICE="${COORD_DEFAULT_SERVICE:-vio-tracker}"

compose() {
  docker compose -f "${COORD_COMPOSE_FILE}" "$@"
}

usage() {
  cat <<'EOF'
Usage: coord <command> [args]

Commands:
  pull              Stop stack, pull images, start stack
  start             docker compose up -d
  stop              docker compose down
  restart           docker compose restart [service]
  status            docker compose ps
  logs [service]    Follow logs (default: all services)
  shell [service]   Interactive shell in service (default: vio-tracker)
  exec <service> <cmd...>  Run command in service container

Environment:
  COORD_COMPOSE_FILE   Default: /opt/stacks/coordinator/compose.yaml
  COORD_ENV_PATH       Default: directory of compose file + /.env
  COORD_DEFAULT_SERVICE Default service for shell: vio-tracker
EOF
}

require_compose_file() {
  if [[ ! -f "${COORD_COMPOSE_FILE}" ]]; then
    echo "coord: compose file not found: ${COORD_COMPOSE_FILE}" >&2
    echo "coord: set COORD_COMPOSE_FILE or install stacks/coordinator to /opt/stacks/coordinator" >&2
    exit 1
  fi
}

cmd="${1:-}"
shift || true

case "${cmd}" in
  pull)
    require_compose_file
    compose down
    compose pull
    compose up -d
    ;;
  start)
    require_compose_file
    compose up -d
    ;;
  stop)
    require_compose_file
    compose down
    ;;
  restart)
    require_compose_file
    compose restart "$@"
    ;;
  status)
    require_compose_file
    compose ps
    ;;
  logs)
    require_compose_file
    if [[ $# -gt 0 ]]; then
      compose logs -f "$@"
    else
      compose logs -f
    fi
    ;;
  shell)
    require_compose_file
    service="${1:-${DEFAULT_SERVICE}}"
    compose exec -it "${service}" bash
    ;;
  exec)
    require_compose_file
    if [[ $# -lt 2 ]]; then
      echo "coord: exec requires <service> <command...>" >&2
      exit 1
    fi
    compose exec -it "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "coord: unknown command: ${cmd}" >&2
    usage >&2
    exit 1
    ;;
esac
