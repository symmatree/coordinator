# Pod stack defaults. Edit on each Pi Zero; do not commit secrets here.
HOSTNAME=pod-NNE

# Image tag for the capture container
POD_CAMERA_VERSION=main

# Local capture target (host bind mount; written to the Zero's SD card)
POD_CAPTURES_DIR=/var/lib/pod/captures

# Host path mounted read-only as /config inside containers
POD_CONFIG_DIR=/var/lib/pod/config

# Capture loop (read by containers/pod-camera/capture.py).
# Keep comments on their own lines: env_file passes values verbatim to the
# container, so a trailing "# ..." would become part of the value.
POD_NODE_NAME=pod-NNE
POD_CAPTURE_HZ=1.0
# Width/height 0 = sensor full resolution (IMX708 4608x2592)
POD_CAPTURE_WIDTH=0
POD_CAPTURE_HEIGHT=0
POD_JPEG_QUALITY=90
# off | server | client -- multi-pod sync is Phase 3 (#24)
POD_SYNC_MODE=off

# Compose profile: empty (host bootstrap only), capture (stills), online (Phase 4)
COMPOSE_PROFILES=capture

DEBUG=false
