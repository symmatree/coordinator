# Coordinator stack defaults. Edit on each Pi; do not commit secrets here.
HOSTNAME=coordinator

# Image tags (images ship in a follow-up PR)
VIO_TRACKER_VERSION=main
VIO_ESTIMATOR_VERSION=main
MAVLINK_VERSION=main
OAK_STILL_CAPTURE_VERSION=main

# Shared Unix socket dir (bind-mounted as /tmp in vision + mavlink containers)
COORDINATOR_IPC_DIR=/var/lib/coordinator/ipc

# Host path mounted read-only as /config (oak_d.yaml, etc.)
COORDINATOR_CONFIG_DIR=/var/lib/coordinator/config

# Host path for OAK-D captures (stills + disparity), mounted as /captures (#72)
COORDINATOR_CAPTURES_DIR=/var/lib/coordinator/captures
# Enables in-tracker capture (disparity + stills) alongside VIO; blank to disable.
# Also the standalone oak-still-capture container's dir. This is the CONTAINER path.
OAK_CAPTURE_DIR=/captures
OAK_JPEG_QUALITY=92
# vio-tracker (VIO-concurrent) capture cadence, #72
OAK_DISPARITY_HZ=1.0
OAK_STILL_HZ=0.2
OAK_STILL_RESOLUTION=12mp
# Still image quality: in flight the ~30 ms auto-exposure (@ ISO 110) smeared every frame. Cap the
# shutter so auto-exposure trades to ISO/gain instead (accept some noise/underexposure for a sharp
# frame); 0 = no cap. OAK_STILL_FOCUS fixes the lens (0-255) to stop AF hunting -- calibrate the value
# on the bench (sharpest var-of-Laplacian at flight distance) before setting; "auto" = leave AF on.
OAK_STILL_MAX_EXPOSURE_US=5000
OAK_STILL_FOCUS=auto
# standalone oak-still-capture (VIO-off, capture profile) cadence/resolution, #73
OAK_CAPTURE_HZ=0.5
OAK_RESOLUTION=12mp

# Serial device for MAVLink to the flight controller (flight profile only).
# Use the REAL node /dev/ttyAMA0, NOT the /dev/serial0 symlink: Docker's `devices:`
# mapping does not follow symlinks, so /dev/serial0 never appears inside the
# container and the router crash-loops on ENOENT. With disable-bt, ttyAMA0 is the
# PL011 primary UART (= what /dev/serial0 points to). Verified on the bench 2026-07-09.
MAVLINK_DEVICE=/dev/ttyAMA0
MAVLINK_BAUD=1500000

# Compose profile: tracker (OAK-D only), bench (+ estimator), flight (+ mavlink).
# flight is the operational default -- the full online system (tracker -> estimator ->
# mavlink). tracker/bench are bring-up/bench-isolation profiles, not normal ops.
COMPOSE_PROFILES=flight

DEBUG=false
