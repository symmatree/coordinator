# Coordinator stack defaults. Edit on each Pi; do not commit secrets here.
HOSTNAME=coordinator

# ghcr.io/symmatree/coordinator-vio tag (image ships in a follow-up PR)
VIO_VERSION=main

# Serial device for MAVLink to the flight controller
MAVLINK_DEVICE=/dev/serial0
MAVLINK_BAUD=1500000

# Host path mounted read-only into vio as /config
COORDINATOR_CONFIG_DIR=/var/lib/coordinator/config

# Passed into container; entrypoint uses when image ships
DEBUG=false
