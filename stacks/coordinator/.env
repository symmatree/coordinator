# Coordinator stack defaults. Edit on each Pi; do not commit secrets here.
HOSTNAME=coordinator

# Image tags (images ship in a follow-up PR)
VIO_TRACKER_VERSION=main
VIO_ESTIMATOR_VERSION=main
MAVLINK_VERSION=main
OAK_STILL_CAPTURE_VERSION=main

# Shared Unix socket dir (bind-mounted as /tmp in vision + mavlink containers)
COORDINATOR_IPC_DIR=/var/lib/coordinator/ipc

# Host path mounted read-only as /config (oak_d.yaml, etc.)
COORDINATOR_CONFIG_DIR=/var/lib/coordinator/config

# Host path for OAK-D RGB stills (capture profile), mounted as /captures (#72)
COORDINATOR_CAPTURES_DIR=/var/lib/coordinator/captures
# OAK still-capture tuning (optional; defaults in capture.py)
OAK_CAPTURE_HZ=0.5
OAK_RESOLUTION=12mp
OAK_JPEG_QUALITY=92

# Serial device for MAVLink to the flight controller (flight profile only)
MAVLINK_DEVICE=/dev/serial0
MAVLINK_BAUD=1500000

# Compose profile: tracker (OAK-D only), bench (+ estimator), flight (+ mavlink)
COMPOSE_PROFILES=tracker

DEBUG=false
